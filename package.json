{
  "name": "@incultnitollc/mcp-probe",
  "version": "1.0.1",
  "type": "module",
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./lib": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "bin": {
    "mcp-probe": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "mcp-tools",
    "mcp-validation",
    "model-context-protocol",
    "validation",
    "validator",
    "schema-validation",
    "testing",
    "diagnostic",
    "ci",
    "cli",
    "developer-tools",
    "pre-publish",
    "ai",
    "llm"
  ],
  "author": "Incultnito LLC",
  "license": "MIT",
  "description": "MCP server validation CLI — fast pre-publish diagnostic for Model Context Protocol servers. Schema validation, tool/resource/prompt health checks, scorecard reporting, CI-ready exit codes.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/incultnitollc/mcp-probe.git"
  },
  "homepage": "https://github.com/incultnitollc/mcp-probe",
  "bugs": {
    "url": "https://github.com/incultnitollc/mcp-probe/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
